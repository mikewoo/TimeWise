{
  "manifest_version": 3,
  "name": "__MSG_extName__",
  "description": "__MSG_extDesc__",
  "version": "1.0.0",
  "default_locale": "en",
  "homepage_url": "https://github.com/mikewoo/TimeWise",
  "icons": {
    "16": "assets/icons/icon-16.png",
    "32": "assets/icons/icon-32.png",
    "48": "assets/icons/icon-48.png",
    "128": "assets/icons/icon-128.png"
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "permissions": ["tabs", "storage", "idle", "alarms", "notifications"],
  "action": {
    "default_title": "TimeWise",
    "default_icon": {
      "16": "assets/icons/icon-16.png",
      "32": "assets/icons/icon-32.png",
      "48": "assets/icons/icon-48.png",
      "128": "assets/icons/icon-128.png"
    }
  },
  "options_ui": {
    "page": "ui/settings.html",
    "open_in_tab": true
  },
  "content_scripts": [{
    "matches": ["<all_urls>"],
    "js": ["ui/toast.js"]
  }],
  "web_accessible_resources": [{
    "resources": ["ui/dashboard.html", "ui/dashboard.js", "ui/settings.html", "ui/settings.js", "lib/db.js", "lib/aggregator.js", "lib/classifier.js", "lib/dexie.mjs", "lib/chart.min.js"],
    "matches": ["<all_urls>"]
  }]
}